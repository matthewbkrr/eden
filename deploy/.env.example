# Copy to `.env` next to docker-compose.yml on the server and fill in.
# NEVER commit the real .env (it holds secrets).

# --- App image (GHCR). The deploy workflow rewrites this to the deployed SHA. ---
APP_IMAGE=ghcr.io/matthewbkrr/eden:latest

# --- Public address -----------------------------------------------------------
# IP phase (initial bring-up):
#   PHX_HOST=95.169.166.216   PHX_SCHEME=http    PHX_PORT=80    SITE_ADDRESS=:80
# Domain phase (after DNS points chat.ihi.ru → server IP):
#   PHX_HOST=chat.ihi.ru      PHX_SCHEME=https   PHX_PORT=443   SITE_ADDRESS=chat.ihi.ru
PHX_HOST=95.169.166.216
PHX_SCHEME=http
PHX_PORT=80
SITE_ADDRESS=:80

# --- Secrets ------------------------------------------------------------------
# Generate locally:  mix phx.gen.secret   (or: openssl rand -base64 48)
SECRET_KEY_BASE=

# --- Postgres -----------------------------------------------------------------
# Use an alphanumeric password — DATABASE_URL is a URL, so `@ : / # ?` in the
# password must be percent-encoded there (an alnum password avoids the trap).
POSTGRES_USER=eden
POSTGRES_PASSWORD=CHANGE-ME-strong-alnum
POSTGRES_DB=eden_prod
# Host is the compose service name `db`. Keep the password in sync with above.
DATABASE_URL=ecto://eden:CHANGE-ME-strong-alnum@db/eden_prod

# --- Media storage (optional) -------------------------------------------------
# Leave blank for the local `uploads` volume. To move media to S3/Cloudflare R2,
# set the bucket (region "auto" for R2/MinIO) — no code change needed.
EDEN_S3_BUCKET=
EDEN_S3_REGION=
EDEN_S3_ENDPOINT=
EDEN_S3_ACCESS_KEY_ID=
EDEN_S3_SECRET_ACCESS_KEY=
