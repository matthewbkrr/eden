# Keep the build context small and avoid leaking local artifacts/secrets.
_build/
deps/
*.plt
priv/plts/

# Assets are built inside the image; node_modules/digested output are not needed.
assets/node_modules/
priv/static/assets/
priv/static/cache_manifest.json

# Local uploads (dev disk storage) must never go into the image.
priv/uploads/

# VCS, CI, editor, and docs.
.git/
.github/
.elixir_ls/
.gitignore
.dockerignore
Dockerfile

# Local env / test artifacts. `**/.env` also catches deploy/.env (the others are
# root-anchored). The Dockerfile's explicit COPY allowlist never copies these
# anyway — this is defense-in-depth.
.env
*.env
**/.env
deploy/
/tmp/
cover/
doc/
