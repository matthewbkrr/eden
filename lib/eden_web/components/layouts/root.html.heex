<!DOCTYPE html>
<html lang={Gettext.get_locale()}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <%!-- Under images/ on purpose: ~p digests these in prod, and Plug.Static's `only` matches
          the digested request only when the path is under a listed PREFIX (images). At the root
          they'd be listed by exact name, which the hashed name doesn't match → 404. images/ keeps
          ~p (so the path picks up the digest AND any script_name prefix) while still serving. --%>
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/images/favicon-32x32.png"} />
    <link rel="icon" type="image/png" sizes="16x16" href={~p"/images/favicon-16x16.png"} />
    <link rel="apple-touch-icon" href={~p"/images/apple-touch-icon.png"} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fcfcfd" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#16181c" />
    <.live_title default="ihichat" suffix=" · ihichat" phx-no-format>{assigns[:page_title]}</.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script nonce={assigns[:csp_nonce]}>
      (() => {
        // Storage throws in some private-browsing / cookies-blocked modes; guard every
        // access so a failure only skips PERSISTENCE (theme still applies for the load),
        // instead of crashing this head IIFE and flashing the default theme.
        const store = {
          get(k) { try { return localStorage.getItem(k); } catch (_) { return null; } },
          set(k, v) { try { localStorage.setItem(k, v); } catch (_) {} },
          del(k) { try { localStorage.removeItem(k); } catch (_) {} },
        };
        const setTheme = (theme) => {
          if (theme === "system") {
            store.del("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            store.set("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(store.get("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
